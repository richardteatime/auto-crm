# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# REQUERIDO: Appwrite (backend / base de datos)
# =============================================================================
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost:80/v1
APPWRITE_PROJECT_ID=tu-proyecto-id
APPWRITE_API_KEY=tu-api-key-server
APPWRITE_DATABASE_ID=crm

# =============================================================================
# OPCIONAL: IA para clasificacion de leads
# Usa OpenRouter (podes elegir el modelo) O Anthropic (fallback)
# Si no se configura ninguno, el CRM usa scoring basado en reglas
# =============================================================================
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini     # Ver modelos: https://openrouter.ai/models
# ANTHROPIC_API_KEY=sk-ant-...            # Fallback si no hay OpenRouter

# =============================================================================
# OPCIONAL: Email digest diario (registrate gratis en resend.com)
# =============================================================================
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=tu@email.com
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>
